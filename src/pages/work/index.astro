---
export const prerender = false;

import { getEmDashCollection, getTaxonomyTerms, getTermsForEntries } from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const activeTag = Astro.url.searchParams.get("tag");

const [{ entries: allProjects, cacheHint }, tags] = await Promise.all([
	getEmDashCollection("projects", {
		limit: 20,
		...(activeTag ? { where: { tag: activeTag } } : {}),
	}),
	getTaxonomyTerms("tag"),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const SLUG_ORDER = [
	"alpha-industries", "coded-in-germany", "bvb", "w-weitz",
	"babor", "iris-von-arnim", "lavera", "lt", "rasch", "e3dc", "bruno-banani",
];
const bySlug = Object.fromEntries(allProjects.map((p) => [p.id, p]));
const projects = SLUG_ORDER.map((s) => bySlug[s]).filter(Boolean);

const tagsByEntry = await getTermsForEntries(
	"projects",
	projects.map((p) => p.data.id),
	"tag",
);

const PROJECT_COLORS: Record<string, string> = {
	"alpha-industries":  "#0000CD",
	"coded-in-germany":  "#FF1493",
	"bvb":               "#FFD700",
	"babor":             "#FF69B4",
	"iris-von-arnim":    "#FFB6C1",
	"lavera":            "#87CEEB",
	"lt":                "#0066FF",
	"rasch":             "#FF4500",
	"e3dc":              "#7BC043",
	"bruno-banani":      "#FF6B00",
};

const PROJECT_IMAGES: Record<string, string> = {
	"alpha-industries":  "/images/alphamu-3000x3000-1-1536x1536-1.webp",
	"coded-in-germany":  "/images/Coded-In-Germany-1-scaled.png",
	"bvb":               "/images/bvbmu_new-scaled.jpg",
	"babor":             "/images/babormu_new-scaled.jpg",
	"iris-von-arnim":    "/images/Iris-Von-Arnim.jpg-scaled.jpg",
	"lavera":            "/images/Lavera-scaled.jpg",
	"lt":                "/images/LT-2025.gif",
	"rasch":             "/images/raschmu_new-scaled.jpg",
	"e3dc":              "/images/E3DC_2025-scaled.jpg",
	"bruno-banani":      "/images/BRUNO-BANANI_2025-scaled.jpg",
};

const activeLabel = activeTag ? tags.find((t) => t.slug === activeTag)?.label : null;
---

<Base title={activeLabel ? `${activeLabel} — Work` : "Work"}>
	<div class="work-page">
		<header class="work-header">
			<div class="work-header-inner">
				<h1 class="work-title">Work</h1>
				{tags.length > 0 && (
					<nav class="tag-filters" aria-label="Filter">
						<a href="/work" class:list={["tag-filter", { active: !activeTag }]}>Alle</a>
						{tags.map((tag) => (
							<a
								href={`/work?tag=${tag.slug}`}
								class:list={["tag-filter", { active: activeTag === tag.slug }]}
							>
								{tag.label}
							</a>
						))}
					</nav>
				)}
			</div>
		</header>

		{projects.length > 0 ? (
			<div class="projects-grid">
				{projects.map((project) => (
					<ProjectCard
						title={project.data.title ?? "Untitled"}
						imgUrl={PROJECT_IMAGES[project.id] ?? ""}
						href={`/work/${project.id}`}
						tags={(tagsByEntry.get(project.data.id) ?? []).map((t) => t.label)}
						color={PROJECT_COLORS[project.id] ?? "#888888"}
					/>
				))}
			</div>
		) : (
			<div class="empty-state">
				{activeTag
					? <><p>Keine Projekte mit diesem Tag.</p><a href="/work" class="btn">Alle Projekte</a></>
					: <p>Noch keine Projekte vorhanden.</p>
				}
			</div>
		)}
	</div>
</Base>

<style>
	.work-page { min-height: 100vh; }

	.work-header {
		background: var(--color-surface);
		border-bottom: 1px solid var(--color-border);
		padding-top: var(--header-height);
	}

	.work-header-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-2xl) var(--spacing-xl) var(--spacing-xl);
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--spacing-xl);
		flex-wrap: wrap;
	}

	.work-title { font-size: var(--font-size-3xl); font-weight: 700; }

	.tag-filters { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); }

	.tag-filter {
		font-size: var(--font-size-sm);
		font-weight: 500;
		text-decoration: none;
		color: var(--color-muted);
		padding: 4px 14px;
		border: 1px solid var(--color-border);
		transition: all var(--transition-fast);
		white-space: nowrap;
	}

	.tag-filter:hover { color: var(--color-text); border-color: var(--color-text); }

	.tag-filter.active {
		color: var(--color-bg);
		background: var(--color-text);
		border-color: var(--color-text);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 3px;
		background: #111;
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-4xl) var(--spacing-lg);
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		margin-top: var(--spacing-lg);
		padding: var(--spacing-sm) var(--spacing-xl);
		background: var(--color-text);
		color: var(--color-bg);
		text-decoration: none;
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	@media (max-width: 640px) {
		.projects-grid { grid-template-columns: 1fr; }
		.work-header-inner { flex-direction: column; }
	}
</style>
