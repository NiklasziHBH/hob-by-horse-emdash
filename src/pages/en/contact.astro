---
import Base from "../../layouts/Base.astro";

let formStatus: "idle" | "success" | "error" = "idle";
let formMessage = "";

if (Astro.request.method === "POST") {
	try {
		const data = await Astro.request.formData();
		const name = data.get("name")?.toString() || "";
		const email = data.get("email")?.toString() || "";
		const message = data.get("message")?.toString() || "";
		if (!name || !email || !message) { formStatus = "error"; formMessage = "Please fill in all fields."; }
		else if (!email.includes("@")) { formStatus = "error"; formMessage = "Please enter a valid email address."; }
		else { formStatus = "success"; formMessage = "Thank you! We'll be in touch soon."; }
	} catch { formStatus = "error"; formMessage = "An error occurred."; }
}
---

<Base title="Contact us" description="Write to us — we look forward to your project.">
	<div class="contact-page">

		<section class="hero">
			<div class="hero-inner">
				<p class="kicker">Contact us</p>
				<h1 class="hero-h1">Let's talk.</h1>
			</div>
		</section>

		<div class="contact-body">
			<div class="contact-form-col">
				{formStatus === "success" ? (
					<div class="form-success"><p>{formMessage}</p><a href="/en/contact" class="form-reset">Send another message</a></div>
				) : (
					<form method="POST" class="contact-form">
						{formStatus === "error" && <div class="form-error"><p>{formMessage}</p></div>}
						<div class="form-row">
							<div class="form-field"><label for="name">Name</label><input type="text" id="name" name="name" required placeholder="Your name" autocomplete="name" /></div>
							<div class="form-field"><label for="email">Email</label><input type="email" id="email" name="email" required placeholder="your@email.com" autocomplete="email" /></div>
						</div>
						<div class="form-field"><label for="company">Company (optional)</label><input type="text" id="company" name="company" placeholder="Your company" /></div>
						<div class="form-field"><label for="message">Message</label><textarea id="message" name="message" required rows="7" placeholder="Tell us about your project..."></textarea></div>
						<button type="submit" class="form-submit">Send message</button>
					</form>
				)}
			</div>

			<aside class="contact-info">
				<div class="info-section"><h3>Hamburg</h3><p>Große Bleichen 1-3<br />20354 Hamburg</p><p><a href="tel:+4954193931034">+49 541 93931034</a></p><p><a href="mailto:info@hob-by-horse.de">info@hob-by-horse.de</a></p></div>
				<div class="info-section"><h3>Osnabrück</h3><p>Natruper Straße 14<br />49076 Osnabrück</p><p><a href="tel:+4954193931034">+49 541 93931034</a></p><p><a href="mailto:info@hob-by-horse.de">info@hob-by-horse.de</a></p></div>
				<div class="info-section"><h3>Social</h3><ul class="social-links"><li><a href="https://www.linkedin.com/company/hob-by-horse" target="_blank" rel="noopener noreferrer">LinkedIn</a></li></ul></div>
			</aside>
		</div>

	</div>
</Base>

<style>
	.contact-page { background: #1a1a1a; color: #ffffff; min-height: 100vh; }
	.hero { padding-top: var(--header-height); border-bottom: 1px solid rgba(255,255,255,0.08); }
	.hero-inner { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-3xl) var(--spacing-xl); }
	.hero-h1 { font-size: clamp(2.2rem,4.5vw,3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; color: #06B6D4; }
	.contact-body { max-width: var(--wide-width); margin: 0 auto; padding: var(--spacing-3xl) var(--spacing-xl) var(--spacing-4xl); display: grid; grid-template-columns: 2fr 1fr; gap: var(--spacing-4xl); align-items: start; }
	.contact-form { display: flex; flex-direction: column; gap: var(--spacing-lg); }
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-lg); }
	.form-field { display: flex; flex-direction: column; gap: var(--spacing-sm); }
	.form-field label { font-size: var(--font-size-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.5); }
	.form-field input, .form-field textarea { padding: var(--spacing-md); font-family: inherit; font-size: var(--font-size-base); color: #ffffff; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); -webkit-appearance: none; }
	.form-field input::placeholder, .form-field textarea::placeholder { color: rgba(255,255,255,0.35); }
	.form-field input:focus, .form-field textarea:focus { outline: none; border-color: #06B6D4; }
	.form-field textarea { resize: vertical; min-height: 160px; }
	.form-submit { align-self: flex-start; padding: var(--spacing-md) var(--spacing-2xl); font-family: inherit; font-size: var(--font-size-sm); font-weight: 700; letter-spacing: 0.04em; color: #ffffff; background: #E7007F; border: none; cursor: pointer; transition: opacity var(--transition-fast); }
	.form-submit:hover { opacity: 0.85; }
	.form-error { padding: var(--spacing-md); background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4); color: #fca5a5; font-size: var(--font-size-sm); }
	.form-success { padding: var(--spacing-2xl); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); }
	.form-success p { font-size: var(--font-size-lg); color: #ffffff; margin-bottom: var(--spacing-lg); }
	.form-reset { font-size: var(--font-size-sm); color: #06B6D4; text-decoration: underline; }
	.contact-info { position: sticky; top: calc(var(--header-height) + var(--spacing-xl)); align-self: start; display: flex; flex-direction: column; gap: var(--spacing-2xl); }
	.info-section h3 { font-size: var(--font-size-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #EAB308; margin-bottom: var(--spacing-sm); }
	.info-section a, .info-section p { font-size: var(--font-size-base); color: rgba(255,255,255,0.75); text-decoration: none; }
	.info-section a:hover { color: #ffffff; }
	.social-links { list-style: none; display: flex; flex-direction: column; gap: var(--spacing-sm); }
	@media (max-width: 1024px) { .contact-body { grid-template-columns: 1fr; gap: var(--spacing-2xl); } .contact-info { position: static; display: grid; grid-template-columns: repeat(3,1fr); gap: var(--spacing-xl); } }
	@media (max-width: 640px) { .hero-h1 { font-size: var(--font-size-3xl); } .form-row { grid-template-columns: 1fr; } .contact-info { grid-template-columns: 1fr; } }
</style>
